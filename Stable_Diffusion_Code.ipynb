            "Skipping 40c298a68522a302b8a22ebf3395194e.jpeg — not found\n",
            "Skipping 56783377d95a87b04c0f10ec52e0ffa7.jpeg — not found\n",
            "Skipping b4b0eeeb1cfc1b7fa8cae06c3bfd3cb8.jpeg — not found\n",
            "Skipping c7c93112a8dd45edeacfe3496ff8a4c9.jpeg — not found\n",
